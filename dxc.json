{
  "backup_dir": ".dxc/backups",
  "health_dir": ".dxc/health",
  "devices": {
    "omarchy": {
      "sources": {
        "zsh": "omarchy/zsh/zshrc",
        "tmux": "omarchy/tmux/tmux.conf",
        "tmux-tdl-pane": "omarchy/tmux/bin/tmux-tdl-pane",
        "tmux-tdl-ui": "omarchy/tmux/bin/tmux-tdl-ui",
        "tmux-help": "omarchy/tmux/help.md"
      },
      "full_apply": [
        {
          "source": "zsh",
          "dest": "~/.zshrc"
        },
        {
          "source": "tmux",
          "dest": "~/.config/tmux/tmux.conf"
        },
        {
          "source": "tmux-tdl-pane",
          "dest": "~/.local/bin/tmux-tdl-pane"
        },
        {
          "source": "tmux-tdl-ui",
          "dest": "~/.local/bin/tmux-tdl-ui"
        },
        {
          "source": "tmux-help",
          "dest": "~/.local/share/tmux/help.md"
        }
      ],
      "full_ingest": [
        {
          "source": "zsh",
          "from": "~/.zshrc"
        },
        {
          "source": "tmux",
          "from": "~/.config/tmux/tmux.conf"
        },
        {
          "source": "tmux-tdl-pane",
          "from": "~/.local/bin/tmux-tdl-pane"
        },
        {
          "source": "tmux-tdl-ui",
          "from": "~/.local/bin/tmux-tdl-ui"
        },
        {
          "source": "tmux-help",
          "from": "~/.local/share/tmux/help.md"
        }
      ]
    },
    "mac": {
      "sources": {
        "zsh": "mac/zsh/zshrc",
        "tmux": "omarchy/tmux/tmux.conf",
        "tmux-tdl-pane": "omarchy/tmux/bin/tmux-tdl-pane",
        "tmux-tdl-ui": "omarchy/tmux/bin/tmux-tdl-ui",
        "tmux-help": "omarchy/tmux/help.md"
      },
      "full_apply": [
        {
          "source": "zsh",
          "dest": "~/.zshrc"
        },
        {
          "source": "tmux",
          "dest": "~/.config/tmux/tmux.conf"
        },
        {
          "source": "tmux-tdl-pane",
          "dest": "~/.local/bin/tmux-tdl-pane"
        },
        {
          "source": "tmux-tdl-ui",
          "dest": "~/.local/bin/tmux-tdl-ui"
        },
        {
          "source": "tmux-help",
          "dest": "~/.local/share/tmux/help.md"
        }
      ],
      "full_ingest": [
        {
          "source": "zsh",
          "from": "~/.zshrc"
        }
      ]
    }
  }
}
